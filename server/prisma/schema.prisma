datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model AnonIdentity {
  id           String         @id @default(uuid())
  sessionToken String         @unique
  createdAt    DateTime       @default(now())
  boards       Board[]
  clips        Clip[]
  profileShare ProfileShare?
}

model Board {
  id         String       @id @default(uuid())
  name       String
  ownerId    String
  owner      AnonIdentity @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shareToken String       @unique
  createdAt  DateTime     @default(now())
  clips      Clip[]

  @@index([ownerId])
}

model Clip {
  id          String       @id @default(uuid())
  boardId     String?
  board       Board?       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       AnonIdentity @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  price       Float?
  currency    String       @default("USD")
  imageUrl    String?
  sourceUrl   String
  storeName   String
  umbrellaTag String
  typeTag     String
  status      String       @default("SUCCESS") // "PENDING", "SUCCESS", "FAILED"
  createdAt   DateTime     @default(now())
  claim       Claim?
  canonicalKey String      @default("")
  priceHistory PriceHistory[]

  @@index([boardId])
  @@index([ownerId])
  @@index([boardId, canonicalKey])
}

model Claim {
  id         String   @id @default(uuid())
  clipId     String   @unique
  clip       Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  claimedAt  DateTime @default(now())
  guestLabel String?
}

model ProfileShare {
  id         String       @id @default(uuid())
  ownerId    String       @unique
  owner      AnonIdentity @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shareToken String       @unique
  createdAt  DateTime     @default(now())
  revokedAt  DateTime?
}

model PriceHistory {
  id         String   @id @default(uuid())
  clipId     String
  clip       Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  price      Float
  currency   String
  capturedAt DateTime @default(now())

  @@index([clipId, capturedAt])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   // scoped by ownerId, same as existing IDOR pattern
  clipId     String
  type       String   // "price_drop" | "price_increase" | "back_in_stock" | "out_of_stock" | "check_failed"
  oldPrice   Float?
  newPrice   Float?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}
